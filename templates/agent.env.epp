<%- | String $server_url, String $tenant_id, String $log_level, String $group_uuid, String $install_dir | -%>
# OnePAM Agent Configuration
# Managed by Puppet — do not edit manually

AGENT_API_URL=<%= $server_url %>
AGENT_TENANT_ID=<%= $tenant_id %>
AGENT_ID=<%= file("${install_dir}/etc/agent-id").chomp %>
AGENT_LOG_LEVEL=<%= $log_level %>
<% if $group_uuid != '' { -%>
AGENT_GROUP_UUID=<%= $group_uuid %>
<% } -%>
